{
  "name": "p5kit-monorepo",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "p5kit-monorepo",
      "version": "0.0.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "p5kit": "bin/p5kit.js"
      }
    },
    "node_modules/@p5kit/bridge": {
      "resolved": "packages/bridge",
      "link": true
    },
    "node_modules/@p5kit/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@p5kit/ios": {
      "resolved": "packages/ios",
      "link": true
    },
    "node_modules/@p5kit/templates": {
      "resolved": "packages/templates",
      "link": true
    },
    "node_modules/create-p5kit": {
      "resolved": "packages/create-p5kit",
      "link": true
    },
    "node_modules/p5kit": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/bridge": {
      "name": "@p5kit/bridge",
      "version": "0.0.0",
      "license": "MIT"
    },
    "packages/cli": {
      "name": "p5kit",
      "version": "0.0.0",
      "license": "MIT",
      "bin": {
        "p5kit": "bin/p5kit.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@p5kit/core",
      "version": "0.0.0",
      "license": "MIT",
      "dependencies": {
        "@p5kit/bridge": "0.0.0"
      }
    },
    "packages/create-p5kit": {
      "version": "0.0.0",
      "license": "MIT",
      "dependencies": {
        "@p5kit/templates": "0.0.0"
      },
      "bin": {
        "create-p5kit": "bin/create-p5kit.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/ios": {
      "name": "@p5kit/ios",
      "version": "0.0.0",
      "license": "MIT"
    },
    "packages/templates": {
      "name": "@p5kit/templates",
      "version": "0.0.0",
      "license": "MIT"
    }
  }
}
