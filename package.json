{
  "name": "p5kit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Toolkit for turning p5.js sketches into iOS apps.",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "p5kit": "./bin/p5kit.js"
  },
  "scripts": {
    "build": "npm --workspaces --if-present run build",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "npm run smoke"
  },
  "homepage": "https://github.com/jinsxk/p5kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinsxk/p5kit.git"
  },
  "bugs": {
    "url": "https://github.com/jinsxk/p5kit/issues"
  },
  "keywords": [
    "p5",
    "p5js",
    "p5.js",
    "android",
    "ios",
    "creative-coding",
    "app"
  ],
  "license": "MIT"
}
